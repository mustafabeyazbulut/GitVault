<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- GitHub Ayarlari -->
    <add key="GitHub:Token" value="ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXX" />
    <add key="GitHub:Organizations" value="OrgAdi1,OrgAdi2" />
    <add key="GitHub:Users" value="KullaniciAdi1,KullaniciAdi2" />
    <add key="GitHub:IgnoreRepos" value="yedeklenmeyecek-repo1,yedeklenmeyecek-repo2" />

    <!-- NAS Kimlik Bilgileri (opsiyonel - bos birakilirsa mevcut oturum yetkileri kullanilir) -->
    <add key="Nas:Username" value="DOMAIN\kullaniciadi" />
    <add key="Nas:Password" value="sifre" />

    <!-- Senkronizasyon Ayarlari -->
    <add key="Sync:DestinationPath" value="\\sunucu\paylasim\yedek" />
    <add key="Sync:CheckIntervalMinutes" value="30" />
    <add key="Sync:MaxVersionsToKeep" value="5" />

    <!-- Email Bildirimi (opsiyonel - bos birakilirsa mail atilmaz) -->
    <add key="Email:To"           value="alici@sirket.com" />
    <add key="Email:SmtpHost"     value="smtp.office365.com" />
    <add key="Email:SmtpPort"     value="587" />
    <add key="Email:SmtpUser"     value="gonderen@sirket.com" />
    <add key="Email:SmtpPassword" value="sifre" />
    <add key="Email:SmtpSsl"      value="true" />
  </appSettings>
</configuration>
